rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Pet subcollection
      match /pets/{petId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Safe Zones subcollection
        match /safeZones/{zoneId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }
        
        // Heatmap subcollection (for analytics)
        match /heatmap/{sessionId}/points/{pointId} {
            allow create: if request.auth != null && request.auth.uid == userId;
            allow read: if request.auth != null && request.auth.uid == userId;
        }
        
        // Activity Points subcollection (for pet pose heatmap)
        match /activityPoints/{pointId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
    
    // Courses are public/auth-read
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
      
      match /days/{dayId} {
        allow read: if true;
        match /steps/{stepId} {
            allow read: if true;
        }
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
